# Required: Plex Media Server connection.
PLEX_URL=http://plex:32400
PLEX_TOKEN=

# Optional: mdblist.com API key. Blank disables ratings + the Discover feed;
# the rest of the service still works. Nightly library sync is configured in the
# dashboard (default on at 03:00).
MDBLIST_API_KEY=

# Optional: Overseerr request/search proxy.
OVERSEERR_URL=
OVERSEERR_API_KEY=

# Optional: OpenSubtitles online subtitle search + download into Plex.
OPENSUBTITLES_API_KEY=
OPENSUBTITLES_USERNAME=
OPENSUBTITLES_PASSWORD=
